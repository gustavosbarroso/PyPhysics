    vy1=widgets.FloatSlider(min=-50, max=50, step=1, value=30, description="vy1 (km/s)"),

    # Corpo 2
    x2=widgets.FloatSlider(min=-2, max=2, step=0.1, value=1, description="x2 (UA)"),
    y2=widgets.FloatSlider(min=-2, max=2, step=0.1, value=0, description="y2 (UA)"),
    vx2=widgets.FloatSlider(min=-50, max=50, step=1, value=0, description="vx2 (km/s)"),
    vy2=widgets.FloatSlider(min=-50, max=50, step=1, value=-30, description="vy2 (km/s)"),

    # Corpo 3
    x3=widgets.FloatSlider(min=-2, max=2, step=0.1, value=0, description="x3 (UA)"),
    y3=widgets.FloatSlider(min=-2, max=2, step=0.1, value=1, description="y3 (UA)"),
    vx3=widgets.FloatSlider(min=-50, max=50, step=1, value=30, description="vx3 (km/s)"),
    vy3=widgets.FloatSlider(min=-50, max=50, step=1, value=0, description="vy3 (km/s)"),

    # Massas
    m1=widgets.FloatSlider(min=0.1, max=5, step=0.1, value=1, description="m1 (M☉)"),
    m2=widgets.FloatSlider(min=0.1, max=5, step=0.1, value=1, description="m2 (M☉)"),
    m3=widgets.FloatSlider(min=0.1, max=5, step=0.1, value=1, description="m3 (M☉)"),

    # Tempo
    t_max=widgets.FloatSlider(min=1, max=20, step=1, value=5, description="Tempo (anos)")
);
