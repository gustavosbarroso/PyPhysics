widgets.interact(
    simular,
    theta1_0=widgets.FloatSlider(min=1, max=120, step=1, value=60, description="θ1₀"),
    theta2_0=widgets.FloatSlider(min=1, max=120, step=1, value=30, description="θ2₀"),

