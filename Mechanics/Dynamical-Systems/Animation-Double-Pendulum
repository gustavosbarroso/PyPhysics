    L2=widgets.FloatSlider(min=0.1, max=2.0, step=0.1, value=0.5, description="L2 (m)"),

    g=widgets.FloatSlider(min=1.0, max=20.0, step=0.5, value=9.81, description="g"),

    m1=widgets.FloatSlider(min=0.1, max=5.0, step=0.1, value=1.0, description="m1"),
    m2=widgets.FloatSlider(min=0.1, max=5.0, step=0.1, value=1.0, description="m2")
)
